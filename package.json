{
  "name": "neogrok",
  "version": "1.2.1",
  "description": "A snappy code search frontend for zoekt",
  "keywords": [
    "code search",
    "grok",
    "zoekt"
  ],
  "homepage": "https://github.com/isker/neogrok",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isker/neogrok.git"
  },
  "bugs": "https://github.com/isker/neogrok/issues",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "./main.js",
    "lint": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings && prettier --check . && eslint --report-unused-disable-directives --max-warnings 0 .",
    "format": "prettier --write .",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "bin": "main.js",
  "files": [
    "build"
  ],
  "author": "Ian Kerins <npm@isk.haus>",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "2.27.12",
    "@eslint/compat": "2.0.2",
    "@eslint/js": "10.0.1",
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/kit": "2.53.4",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tailwindcss/vite": "4.2.1",
    "@types/lucene": "2.1.5",
    "@types/node": "24.11.0",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.15.0",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "5.53.6",
    "svelte-check": "4.4.4",
    "tailwindcss": "4.2.1",
    "type-fest": "4.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "@badrap/valita": "0.4.6",
    "lucene": "2.1.1",
    "lucide-svelte": "0.475.0",
    "pretty-bytes": "6.1.1",
    "prom-client": "15.1.3",
    "shiki": "4.0.1"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.6.0",
  "resolutions": {
    "is-core-module": "npm:@nolyfill/is-core-module@^1",
    "safer-buffer": "npm:@nolyfill/safer-buffer@^1"
  }
}
